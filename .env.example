APP_NAME="Clideo Video Converter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=video_converter
DB_USERNAME=video_converter
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=file

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=local
VIDEO_INPUT_DISK=local
VIDEO_OUTPUT_DISK=public
VIDEO_CONVERSION_QUEUE=video-conversions
VIDEO_POST_PROCESSING_QUEUE=video-post-processing

FFMPEG_BINARY=/usr/bin/ffmpeg
FFPROBE_BINARY=/usr/bin/ffprobe
FFMPEG_TIMEOUT=1800

LIGHTHOUSE_SECURITY_MAX_QUERY_COMPLEXITY=1000
LIGHTHOUSE_SECURITY_MAX_QUERY_DEPTH=10
LIGHTHOUSE_SECURITY_DISABLE_INTROSPECTION=0
